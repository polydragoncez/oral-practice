# ===========================================
# English Speaking Practice App - Environment Variables
# ===========================================
# Note: API keys are entered by users in the app's Settings page
# and stored in their browser's localStorage.
# These environment variables are NOT required for the app to run.
# They are listed here for reference only.

# --- Optional: For Cloudflare Worker Proxy (future) ---
# GEMINI_API_KEY=your_gemini_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here
# AZURE_SPEECH_KEY=your_azure_speech_key_here
# AZURE_SPEECH_REGION=eastus

# --- App runs as pure static site, no env vars needed ---
